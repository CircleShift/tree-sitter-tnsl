{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tnsl",
      "camelcase": "TNSL",
      "title": "TNSL",
      "scope": "source.tnsl",
      "file-types": [
        "tnsl"
      ],
      "injection-regex": "^tnsl$",
      "class-name": "TreeSitterTnsl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "TNSL Language Parser",
    "authors": [
      {
        "name": "Kai Gunger",
        "email": "kgunger@gmail.com",
        "url": "https://cshift.net/"
      }
    ],
    "links": {
      "repository": "https://github.com/CircleShift/tree-sitter-tnsl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}